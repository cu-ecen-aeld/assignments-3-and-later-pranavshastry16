#!/bin/sh
#
# aesdsocket-start-stop
#
# SysV init script used by Buildroot target to start/stop aesdsocket.
#
# For Assignment 8:
#   - aesdsocket runs in daemon mode using -d
#   - aesdsocket talks to /dev/aesdchar, not /var/tmp/aesdsocketdata
#   - the driver startup is handled separately by S98lddmodules
#

case "$1" in
    start)
        echo "Starting aesdsocket..."

        #
        # Run aesdsocket in daemon mode.
        # The binary is installed to /usr/bin by the aesd-assignments package.
        #
        /usr/bin/aesdsocket -d
        ;;

    stop)
        echo "Stopping aesdsocket..."

        #
        # Kill the daemon if it is running.
        # Suppress errors if it is already stopped.
        #
        killall aesdsocket 2>/dev/null || true
        ;;

    restart)
        #
        # Standard restart behavior
        #
        $0 stop
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
